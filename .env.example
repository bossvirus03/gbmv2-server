# Server Configuration
PORT=3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/db_name?schema=public

# Authentication
JWT_SECRET=your_super_secret_jwt_key
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
ADMIN_EMAILS=admin@example.com,user@example.com

# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your_cloudflare_r2_account_id
R2_ACCESS_KEY=your_cloudflare_r2_access_key
R2_SECRET_KEY=your_cloudflare_r2_secret_key
R2_BUCKET=your_cloudflare_r2_bucket_name
R2_PUBLIC_URL=https://your-r2-public-url.com
